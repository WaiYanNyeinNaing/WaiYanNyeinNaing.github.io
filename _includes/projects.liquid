<div class="col">
  <div class="card h-100 hoverable">
    {% if project.img %}
      <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
        {%
          include figure.liquid
          loading="eager"
          path=project.img
          sizes = "250px"
          alt="project thumbnail"
          class="card-img-top"
        %}
      </a>
    {% endif %}
    <div class="card-body">
      <h3 class="card-title">
        <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" style="color: inherit; text-decoration: none;">
          {{ project.title }}
        </a>
      </h3>
      <p class="card-text" style="font-size: 0.95rem; color: var(--global-text-color-light);">{{ project.description }}</p>
      
      {% if project.github %}
        <hr class="mt-4 mb-3">
        <div class="project-links d-flex align-items-center">
          <a href="{{ project.github }}" target="_blank" class="btn btn-sm btn-outline-dark d-flex align-items-center" style="border-radius: 20px; padding: 0.25rem 0.75rem;">
            <i class="fa-brands fa-github mr-2"></i>
            <span>View Repository</span>
          </a>
          {% if project.github_stars %}
            <span class="stars ml-3 text-muted" style="font-size: 0.85rem;">
              <i class="fa-solid fa-star mr-1"></i>
              <span id="{{ project.github_stars }}-stars"></span>
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
